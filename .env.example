# LLM (OpenRouter)
# Single key (simple):
OPENROUTER_API_KEY=sk-or-your-key-here
# Multi-key rotation — agent rotates automatically when one key hits HTTP 402 (credit exhausted).
# When set, takes precedence over OPENROUTER_API_KEY.
# OPENROUTER_API_KEYS=sk-or-key1,sk-or-key2,sk-or-key3
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# MCP Toolbox
MCP_TOOLBOX_URL=http://localhost:5000

# Databases (read by MCP Toolbox process, not agent directly)
POSTGRES_USER=oracle_forge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=oracle_forge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=oracle_forge

# Agent server
AGENT_PORT=8000
