# Agent runtime
AGENT_OFFLINE_MODE=0
AGENT_MAX_TOKENS=700
AGENT_TEMPERATURE=0.1
AGENT_TIMEOUT_SECONDS=45
AGENT_USE_MCP=1
MCP_TOOLBOX_URL=http://localhost:5000
MCP_TIMEOUT_SECONDS=8
AGENT_USE_SANDBOX=0
SANDBOX_URL=http://localhost:8080
SANDBOX_TIMEOUT_SECONDS=12
# --- Sandbox server-side settings (used by sandbox/sandbox_server.py) ---
SANDBOX_PORT=8080
SANDBOX_HOST=0.0.0.0
# Comma-separated absolute roots sandbox can access (server-side enforcement)
SANDBOX_ALLOWED_ROOTS=
SANDBOX_MAX_PAYLOAD_CHARS=50000
SANDBOX_PY_TIMEOUT_SECONDS=3
# Set to 0 to enable sandbox HTTP access logging
SANDBOX_QUIET=1
AGENT_SELF_CORRECTION_RETRIES=3
AGENT_MAX_EXECUTION_STEPS=6
AGENT_MEMORY_ROOT=.oracle_forge_memory
AGENT_RUNTIME_EVENTS_PATH=.oracle_forge_memory/events.jsonl
AGENT_CORRECTIONS_LOG_PATH=kb/corrections/corrections_log.md
AGENT_CONTEXT_PATH=agent/AGENT.md
AGENT_MEMORY_SESSION_ITEMS=12
AGENT_MEMORY_TOPIC_CHARS=2500
AGENT_SESSION_ID=

# OpenRouter (required when AGENT_OFFLINE_MODE=0) — FR-13
OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=openai/gpt-5-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=oracle-forge-agent

# DuckDB custom MCP bridge (FR-03b) — no default pointing to live server (SEC-09)
DUCKDB_BRIDGE_URL=http://localhost:5001
DUCKDB_BRIDGE_TIMEOUT_SECONDS=8

# tools.yaml path (FR-03)
TOOLS_YAML_PATH=./tools.yaml

# Optional local DB vars (used by MCP toolbox configs)
POSTGRES_URL=postgresql://oracle_forge:oracle_forge@localhost:5432/oracle_forge
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=oracle_forge
SQLITE_PATH=./data/sqlite/main.db
DUCKDB_PATH=./data/duckdb/main.duckdb

# Logging
LOG_LEVEL=INFO

# Shared-server/public live endpoint used in README evidence
LIVE_AGENT_URL=https://oracle-forge-sandbox.yohannesdereje1221.workers.dev/
