# Agent runtime
AGENT_OFFLINE_MODE=1
AGENT_MAX_TOKENS=700
AGENT_TEMPERATURE=0.1
AGENT_TIMEOUT_SECONDS=45
AGENT_USE_MCP=1
MCP_TOOLBOX_URL=http://localhost:5000
MCP_TIMEOUT_SECONDS=8
AGENT_USE_SANDBOX=0
SANDBOX_URL=http://localhost:8080
SANDBOX_TIMEOUT_SECONDS=12
# Comma-separated absolute roots sandbox can access (server-side enforcement)
SANDBOX_ALLOWED_ROOTS=
AGENT_SELF_CORRECTION_RETRIES=1
AGENT_MAX_EXECUTION_STEPS=6
AGENT_MEMORY_ROOT=.oracle_forge_memory
AGENT_RUNTIME_EVENTS_PATH=.oracle_forge_memory/events.jsonl
AGENT_CORRECTIONS_LOG_PATH=kb/corrections/corrections_log.md
AGENT_CONTEXT_PATH=agent/AGENT.md
AGENT_MEMORY_SESSION_ITEMS=12
AGENT_MEMORY_TOPIC_CHARS=2500
AGENT_SESSION_ID=

# OpenRouter (enable when AGENT_OFFLINE_MODE=0)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=oracle-forge-agent
MODEL=openrouter/auto

# Optional local DB vars (used by MCP toolbox configs)
POSTGRES_URL=postgresql://oracle_forge:oracle_forge@localhost:5432/oracle_forge
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=oracle_forge
SQLITE_PATH=./data/sqlite/main.db
DUCKDB_PATH=./data/duckdb/main.duckdb
